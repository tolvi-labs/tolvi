{
  "name": "@tolvi-labs/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tolvi server — multi-tenant Fastify + Postgres + pgvector implementation of tolvi-format-v1.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "migrate": "drizzle-kit migrate",
    "migrate:generate": "drizzle-kit generate",
    "test": "vitest run --project unit --project integration",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "lint": "tsc --noEmit",
    "openapi:dump": "tsx src/scripts/openapi-dump.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@node-rs/argon2": "^2.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^20.16.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.10",
    "testcontainers": "^11.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
