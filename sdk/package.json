{
  "name": "@tolvi-labs/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Tolvi API",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "gen:types": "openapi-typescript ../spec/openapi.json -o src/types.gen.ts --alphabetize",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:contract": "vitest run test/contract",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run gen:types && npm run build && npm test"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "openapi-typescript": "^7.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tolvi-labs/tolvi.git",
    "directory": "sdk"
  },
  "license": "Apache-2.0",
  "keywords": ["tolvi", "sdk", "rag", "vault"]
}
